---
layout: "blog-gallery.njk"
pagination:
  data: collections
  size: 1
  alias: tag
permalink: /tags/{{ tag }}/
excludeFromSitemap: true
image: og_images.jpg
---
{% include 'partials/page_partials/_img_hero.html' %}
<div id="primary" class="content-area column two-thirds">
  <main id="main" class="site-main" role="main">
  <aside id="recent-posts-2" class="widget widget_recent_entries">
      <h1 class="entry-title">Keyword: {{ tag }}</h1>
      <br>
      <p>The following posts are related to the topic.</p>
      <ul>
      {% set taglist = collections[ tag ] %}
      {% for post in taglist | reverse %}
        <li><a href="{{ post.url }}">{{ post.data.description }}</a></li>
      {% endfor %}
      </ul>
  </aside>
  </main>
</div>